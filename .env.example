# LLM API配置（支持 OpenAI SDK 格式的任意 LLM API）
# 推荐使用阿里百炼平台qwen-plus模型：https://bailian.console.aliyun.com/
# 注意消耗较大，可先进行小于40轮的模拟尝试
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL_NAME=qwen-plus

# ===== ZEP记忆图谱配置 =====
# 每月免费额度即可支撑简单使用：https://app.getzep.com/
ZEP_API_KEY=your_zep_api_key_here

# ===== Model Role Configuration (Optional) =====
# Route different tasks to different models for cost/quality balance.
# All role settings fall back to LLM_* defaults when not set.
#
# "strong" role — quality-critical tasks: report generation, ontology building
#   Recommended: gpt-4o, claude-3-5-sonnet-20241022, gemini-1.5-pro
MODEL_STRONG_API_KEY=
MODEL_STRONG_BASE_URL=
MODEL_STRONG_NAME=gpt-4o

# "fast" role — bulk/cheap tasks: agent-profile generation, simulation config
#   Recommended: gpt-4o-mini, gemini-1.5-flash, qwen-turbo
#   Leave blank to use LLM_* defaults (cheapest option already)
MODEL_FAST_API_KEY=
MODEL_FAST_BASE_URL=
MODEL_FAST_NAME=gpt-4o-mini

# "local" role — dev/testing via Ollama (free, runs on your machine)
#   1. Install Ollama: https://ollama.ai
#   2. Pull a model:  ollama pull llama3.2
#   3. Set MODEL_LOCAL_NAME to the model you pulled
MODEL_LOCAL_API_KEY=ollama
MODEL_LOCAL_BASE_URL=http://localhost:11434/v1
MODEL_LOCAL_NAME=llama3.2

# ===== 加速 LLM 配置（已废弃，由 Model Roles 替代）=====
# LLM_BOOST_API_KEY=your_api_key_here
# LLM_BOOST_BASE_URL=your_base_url_here
# LLM_BOOST_MODEL_NAME=your_model_name_here
# ===== 安全配置 =====
# 生产环境必须设置（建议用: python -c "import secrets; print(secrets.token_hex(32))"）
SECRET_KEY=change-me-generate-with-python-secrets

# 允许的跨域来源（逗号分隔，生产环境改为实际域名）
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# 生产环境务必改为 False
FLASK_DEBUG=False

# Analytics (optional — leave blank to disable)
VITE_ANALYTICS_ENDPOINT=
